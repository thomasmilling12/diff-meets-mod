# Copy this file to pi/.env and fill in your values.
# This file is loaded by the systemd service on your Pi.

# Required: Your Discord bot token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Required: Port for the Express health server
PORT=3000

# Optional: Path to the SQLite database file (default: ./data/bot.db)
DB_PATH=/home/pi/diff-meets-mod/data/bot.db

# Optional: Node environment
NODE_ENV=production
